{
  "stock_analyzer": {
    "name": "股票分析器",
    "description": "A股技术分析与基本面分析",
    "category": "股票分析",
    "type": "table",
    "endpoint": "api/stock/analyze",
    "gridData": {
      "w": 24,
      "h": 10
    },
    "source": "Tushare + OpenBB",
    "params": [
      {
        "paramName": "stock_code",
        "value": "000001.SZ",
        "label": "股票代码",
        "type": "text",
        "description": "深圳股票以.SZ结尾，上海股票以.SH结尾"
      },
      {
        "paramName": "days",
        "value": 90,
        "label": "分析周期(天)",
        "type": "number",
        "description": "技术指标分析周期",
        "min": 30,
        "max": 365
      },
      {
        "paramName": "indicators",
        "value": [
          "MA",
          "MACD",
          "RSI"
        ],
        "label": "技术指标",
        "type": "dropdown",
        "description": "选择要计算的技术指标",
        "options": [
          "MA",
          "MACD",
          "RSI",
          "Bollinger"
        ]
      },
      {
        "paramName": "show_financial",
        "value": false,
        "label": "显示财务数据",
        "type": "boolean",
        "description": "是否显示财务报表数据"
      }
    ],
    "columnsDefs": [
      {
        "field": "trade_date",
        "headerName": "交易日期"
      },
      {
        "field": "close_adj",
        "headerName": "收盘价(复权)"
      },
      {
        "field": "ma20",
        "headerName": "MA20"
      },
      {
        "field": "rsi",
        "headerName": "RSI"
      },
      {
        "field": "signal",
        "headerName": "买卖信号",
        "cellRenderer": "signalRenderer"
      }
    ]
  },
  "financial_data": {
    "name": "财务数据",
    "description": "资产负债表和利润表",
    "category": "财务分析",
    "type": "table",
    "endpoint": "api/financial/data",
    "gridData": {
      "w": 24,
      "h": 8
    },
    "source": "Tushare",
    "params": [
      {
        "paramName": "stock_code",
        "value": "000001.SZ",
        "label": "股票代码",
        "type": "text",
        "description": "要查询的股票代码"
      }
    ],
    "columnsDefs": [
      {
        "field": "ts_code",
        "headerName": "股票代码"
      },
      {
        "field": "end_date",
        "headerName": "报告期"
      },
      {
        "field": "assets",
        "headerName": "总资产(万元)"
      },
      {
        "field": "equity",
        "headerName": "股东权益(万元)"
      },
      {
        "field": "roe",
        "headerName": "净资产收益率(%)"
      }
    ]
  },
  "ai_analysis": {
    "name": "AI 技术分析",
    "description": "使用智谱AI进行股票分析",
    "category": "AI分析",
    "type": "markdown",
    "endpoint": "api/ai/analyze",
    "gridData": {
      "w": 24,
      "h": 12
    },
    "source": "智谱AI",
    "params": [
      {
        "paramName": "content",
        "value": "",
        "label": "分析内容",
        "type": "text",
        "description": "输入要分析的内容"
      }
    ]
  },
  "ai_recommendation": {
    "name": "AI 选股建议",
    "description": "基于AI分析的股票推荐",
    "category": "选股",
    "type": "table",
    "endpoint": "api/ai/stock-recommendation",
    "gridData": {
      "w": 24,
      "h": 8
    },
    "source": "智谱AI",
    "params": []
  }
}
